@model CustomerInvoicesViewModel

@{
    ViewData["Title"] = $"{Model.CustomerName} — Invoices";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Customers</a></li>
        <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.CustomerId">@Model.CustomerName</a></li>
        <li class="breadcrumb-item active">Invoices</li>
    </ol>
</nav>

<h1>Invoices for <span class="text-muted">@Model.CustomerName</span></h1>

@if (!Model.Invoices.Any())
{
    <div class="alert alert-info mt-3">
        This customer has no invoices yet.
        <a asp-controller="Invoices" asp-action="Create">Create one</a>.
    </div>
}
else
{
    <table class="table table-hover mt-3">
        <thead class="table-light">
            <tr>
                <th>#</th>
                <th>Date</th>
                <th class="text-center">Lines</th>
                <th class="text-end">Total</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var inv in Model.Invoices)
            {
                <tr>
                    <td>@inv.InvoiceId</td>
                    <td>@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                    <td class="text-center">@inv.LineCount</td>
                    <td class="text-end">£@inv.Total.ToString("N2")</td>
                    <td class="text-end">
                        <a asp-action="InvoiceDetail" asp-route-id="@inv.InvoiceId"
                           class="btn btn-sm btn-outline-secondary">View Invoice</a>
                    </td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-light">
                <td colspan="3" class="text-end fw-semibold">Total across all invoices:</td>
                <td class="text-end fw-bold">£@Model.Invoices.Sum(i => i.Total).ToString("N2")</td>
                <td></td>
            </tr>
        </tfoot>
    </table>
}

<a asp-action="Details" asp-route-id="@Model.CustomerId" class="btn btn-outline-secondary mt-2">
    Back to Customer
</a>

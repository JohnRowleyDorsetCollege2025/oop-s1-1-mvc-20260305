@model IEnumerable<CustomerSummaryViewModel>

@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Customers</h1>
    <a asp-action="Create" class="btn btn-primary">+ New Customer</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No customers yet. <a asp-action="Create">Add one</a>.</div>
}
else
{
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th class="text-center">Invoices</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Name</td>
                    <td class="text-center">
                        @if (c.InvoiceCount > 0)
                        {
                            <a asp-action="Invoices" asp-route-id="@c.Id">@c.InvoiceCount</a>
                        }
                        else
                        {
                            <span class="text-muted">0</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">View</a>
                        <a asp-action="Invoices" asp-route-id="@c.Id" class="btn btn-sm btn-outline-info">Invoices</a>
                        <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@c.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
